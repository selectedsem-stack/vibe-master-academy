# .env.example — תבנית לקובץ .env
# העתק את הקובץ הזה ל-.env, ושים בו את ה-API key האמיתי שלך מ-console.anthropic.com
# חשוב: הקובץ .env לא יועלה ל-git (הוא ב-.gitignore). זה הקובץ שמכיל סודות.
#
# חשוב פעמיים: ה-API key המלא כבר מתחיל ב-"sk-ant-api03-" משלו.
# אל תוסיף את הקידומת הזאת שוב — פשוט הדבק את כל המפתח כפי שהעתקת
# מ-console.anthropic.com אחרי הסימן =.

ANTHROPIC_API_KEY=
